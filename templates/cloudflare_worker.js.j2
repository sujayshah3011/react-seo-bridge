const BOT_UA_RE = new RegExp('{{ bot_regex }}', 'i');
const SKIP_EXTENSIONS = /\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|map)$/i;

export default {
  async fetch(request, env, ctx) {
    const url = new URL(request.url);
    const ua = request.headers.get('user-agent') || '';

    if (
      request.method !== 'GET' ||
      !BOT_UA_RE.test(ua) ||
      SKIP_EXTENSIONS.test(url.pathname) ||
      url.pathname.startsWith('/api/')
    ) {
      return fetch(request);
    }

    const prerenderUrl = env.RSB_PRERENDER_URL || '{{ prerender_url }}';
    if (!prerenderUrl) {
      return fetch(request);
    }

    try {
      const prerenderRes = await fetch(
        `${prerenderUrl}/render?url=${encodeURIComponent(request.url)}`,
        { headers: { 'X-RSB-Request': '1' } }
      );

      if (!prerenderRes.ok) {
        return fetch(request);
      }

      const html = await prerenderRes.text();
      return new Response(html, {
        status: 200,
        headers: {
          'Content-Type': 'text/html; charset=utf-8',
          'X-RSB-Prerendered': '1',
          'Cache-Control': 'public, max-age=3600'
        }
      });
    } catch {
      return fetch(request);
    }
  }
};
