 * Generated by rsb inject.
 */

const BOT_UA_RE = new RegExp('{{ bot_regex }}', 'i');
const PRERENDER_URL = process.env.RSB_PRERENDER_URL || '{{ prerender_url }}';
const SKIP_EXT = /\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|map)$/i;

module.exports = async function rsbPrerenderMiddleware(req, res, next) {
  const ua = req.headers['user-agent'] || '';

  if (
    req.method !== 'GET' ||
    !BOT_UA_RE.test(ua) ||
    SKIP_EXT.test(req.path) ||
    req.path.startsWith('/api/')
  ) {
    return next();
  }

  const fullUrl = `${req.protocol}://${req.get('host')}${req.originalUrl}`;

  try {
    const response = await fetch(
      `${PRERENDER_URL}/render?url=${encodeURIComponent(fullUrl)}`
    );
    if (!response.ok) return next();
    const html = await response.text();
    res.setHeader('Content-Type', 'text/html; charset=utf-8');
    res.setHeader('X-RSB-Prerendered', '1');
    return res.send(html);
  } catch {
    return next();
  }
};
