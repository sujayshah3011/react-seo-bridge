import { NextResponse } from 'next/server';

const BOT_UA_RE = new RegExp('{{ bot_regex }}', 'i');
const STATIC_ASSET_RE = /\.(js|css|png|jpg|jpeg|gif|svg|ico|woff|woff2|ttf|eot|map)$/i;
const PRERENDER_URL = process.env.RSB_PRERENDER_URL || '{{ prerender_url }}';

export async function middleware(request) {
  const ua = request.headers.get('user-agent') || '';
  const { pathname } = request.nextUrl;

  if (
    request.method !== 'GET' ||
    !BOT_UA_RE.test(ua) ||
    !PRERENDER_URL ||
    pathname.startsWith('/api/') ||
    pathname.startsWith('/_next/') ||
    pathname.startsWith('/static/') ||
    STATIC_ASSET_RE.test(pathname)
  ) {
    return NextResponse.next();
  }

  try {
    const prerenderRes = await fetch(
      `${PRERENDER_URL}/render?url=${encodeURIComponent(request.url)}`,
      { headers: { 'X-RSB-Request': '1' } }
    );

    if (!prerenderRes.ok) {
      return NextResponse.next();
    }

    const html = await prerenderRes.text();
    return new Response(html, {
      status: 200,
      headers: {
        'Content-Type': 'text/html; charset=utf-8',
        'X-RSB-Prerendered': '1',
        'Cache-Control': 'public, max-age=3600'
      }
    });
  } catch {
    return NextResponse.next();
  }
}

export const config = {
  matcher: ['/((?!_next/static|_next/image|favicon.ico).*)']
};
